# =====================================================
# Archivo de Ejemplo - Copia a .env y completa con tus datos
# =====================================================

# =====================================================
# SUPABASE CONFIGURATION
# Obtén estos datos de https://supabase.com/dashboard
# =====================================================

# URL del proyecto Supabase
# Formato: https://xxxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Clave pública (anon) - usar en frontend
# Visible públicamente (OK)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjU2MDAwMDAwLCJleHAiOjE5NzEzMDAwMDB9.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clave secreta (service_role) - usar en backend
# ⚠️ NUNCA compartir públicamente o en repositorio
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJzZXJ2aWNlX3JvbGUiLCJpYXQiOjE2NTYwMDAwMDAsImV4cCI6MTk3MTMwMDAwMH0.yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# URL directa de la base de datos PostgreSQL (opcional)
# Formato: postgresql://postgres:password@host:5432/postgres
DATABASE_URL=postgresql://postgres:your_password@your-project-id.supabase.co:5432/postgres

# =====================================================
# NODE.JS CONFIGURATION
# =====================================================

# Ambiente: development, production, testing
NODE_ENV=development

# Puerto en el que correrá el servidor
PORT=3000

# Secreto para sessions (usar algo aleatorio y fuerte)
# Generar con: openssl rand -base64 32
SESSION_SECRET=tu-super-secreto-aqui-generado-aleatoriamente

# =====================================================
# APLICACIÓN CONFIGURATION
# =====================================================

# Nombre de la aplicación
APP_NAME=MisFinanzas

# Modo de logging
LOG_LEVEL=debug

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# =====================================================
# OPCIONALES - PARA FUTURAS INTEGRACIONES
# =====================================================

# Email configuration (si integras envío de emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=tu-contraseña

# Stripe (si integras pagos)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxx

# Google Analytics
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# =====================================================
# INSTRUCCIONES
# =====================================================
# 
# 1. Copia este archivo: .env.example → .env
# 2. Reemplaza los valores con tus credenciales reales
# 3. Nunca commits .env a Git
# 4. Añade .env al .gitignore
#
# Para obtener las credenciales de Supabase:
# - Ve a https://supabase.com/dashboard
# - Selecciona tu proyecto
# - Settings > API
# - Copia las claves
#
# =====================================================
